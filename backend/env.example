# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database Configuration
DB_PATH=./data/biblebus.db

# Email Configuration (Gmail)
EMAIL_USER=jaklilu@gmail.com
EMAIL_APP_PASSWORD=your-gmail-app-password-here
# Alternates (if the dashboard key was mistyped): GMAIL_APP_PASSWORD, EMAIL_PASSWORD
# Optional: comma-separated BCC addresses on every donor donation-thank-you (defaults to jaklilu@gmail.com if unset)
# DONATION_CONFIRM_BCC_EMAIL=jaklilu@gmail.com

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# Backend URL (for WhatsApp tracking links in emails)
# Production: https://the-bibel-bus-v2.onrender.com
# Development: http://localhost:5002
BACKEND_URL=http://localhost:5002

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Stripe (donations)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook endpoint: POST /api/auth/stripe-webhook — enable events: payment_intent.succeeded, checkout.session.completed
# FRONTEND_URL must match your live site (Stripe Checkout success/cancel URLs), e.g. https://thebiblebus.net
# Milestone WhatsApp check-in (public): {FRONTEND_URL}/milestone-checkin?m=1  (m=1..8)
